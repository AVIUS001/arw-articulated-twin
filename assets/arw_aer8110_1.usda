      float physics:lowerLimit = -0.43633
      float physics:upperLimit = 0.43633
      float drive:stiffness = 8000
      float drive:damping = 400
    }
    def Torus "ring_tube_A" (majorRadius = 1.1000, minorRadius = 0.02)
    {
      color3f[] primvars:displayColor = [(0.35, 0.35, 0.4)]
    }
  }
