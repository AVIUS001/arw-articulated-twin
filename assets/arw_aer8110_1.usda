#usda 1.0
(
  custom string arw:vehicleCode = "AER8110-1"
  custom string arw:cadDrawing = "AER8110-1 RING-WING ASSY - 19X PROPULSION UNITS SET A"
  custom int arw:rotorCount = 19
  custom string arw:propulsion = "I-C2E Snidget Rev D (AV5008TM-HV)"
  custom string license = "Apache-2.0"
  custom string notice = "Patent-pending articulation control — reference allocator only"
)

def Xform "ARW" (
  uniform token physics:approximation = "none"
  custom vector3f physics:gravity = (0, 0, -9.81)
)
{
  def PhysicsScene "physicsScene"
  {
    uniform vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
  }
  def Xform "hub" (
    prepend apiSchemas = ["PhysicsArticulationRootAPI", "PhysicsRigidBodyAPI", "PhysicsMassAPI"]
  )
  {
    float physics:mass = 6.7200
    bool physics:rigidBodyEnabled = true
    point3f physics:centerOfMass = (0, 0, 0)
    def Cylinder "hub_geom" (radius = 0.0807, height = 0.0645)
    {
      color3f[] primvars:displayColor = [(0.2, 0.2, 0.25)]
    }
  }
  def Xform "ring_A" (
    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
  )
  {
    float physics:mass = 2.3040
    bool physics:rigidBodyEnabled = true
    def PhysicsRevoluteJoint "hinge_A" (
      prepend apiSchemas = ["PhysicsDriveAPI"]
    )
    {
